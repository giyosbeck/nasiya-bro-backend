# Copy to .env and fill with real values. Never commit .env.

# Environment: development | staging | production
ENVIRONMENT=development

# Database (PostgreSQL recommended; SQLite only for quick dev)
DATABASE_URL=postgresql://nasiya_user:CHANGE_ME@localhost:5432/nasiya_bro

# Security — REQUIRED. Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Token lifetimes (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Admin bootstrap — REQUIRED for first-run setup. Change immediately after.
DEFAULT_ADMIN_USERNAME=
DEFAULT_ADMIN_PASSWORD=

# CORS — comma-separated origins. No defaults in production.
BACKEND_CORS_ORIGINS_RAW=https://nasiya.backend.leadai.uz,http://localhost:8081

# File upload
UPLOAD_FOLDER=uploads
MAX_FILE_SIZE=10485760

# Timezone
TIMEZONE=Asia/Tashkent

# Error tracking (optional)
SENTRY_DSN=
